# Plaud API token (get from web.plaud.ai > DevTools > localStorage > tokenstr)
PLAUD_TOKEN=bearer eyJ...

# Groq API key (free tier, get from console.groq.com)
GROQ_API_KEY=gsk_...

# OpenAI API key (optional — only needed for recordings longer than 90 minutes)
OPENAI_API_KEY=sk-...

# Email settings (optional — for sending meeting notes via Resend)
EMAIL_FROM=noreply@example.com
EMAIL_TO=you@example.com
RESEND_API_KEY=re_...
